{
  "enabled": {
    "description": "是否启用“没品”自动回复功能",
    "type": "bool",
    "hint": "开启后，当监控列表中的用户发送消息时，会以设定概率自动回复“没品”。",
    "default": false,
    "obvious_hint": true
  },
  "probability": {
    "description": "触发“没品”回复的概率（0-100）",
    "type": "int",
    "hint": "设置0到100之间的整数，表示触发回复的百分比概率。例如：10表示10%概率回复。",
    "default": 10,
    "options": [
      0,
      5,
      10,
      15,
      20,
      25,
      30,
      40,
      50,
      60,
      70,
      80,
      90,
      100
    ],
    "slider": {
      "min": 0,
      "max": 100,
      "step": 1
    }
  },
  "monitored_users": {
    "description": "被监控的用户ID列表",
    "type": "list",
    "hint": "输入平台唯一用户ID（如QQ号、Telegram ID等），插件将仅对列表中的用户触发回复。支持多用户，每行一个ID。",
    "default": [],
    "editor_mode": true,
    "editor_language": "text",
    "editor_theme": "vs-light"
  }
}